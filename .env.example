# API Configuration
# Local dev: the Vite proxy (vite.config.ts) forwards /api to VITE_API_PROXY
# Production (GitHub Pages): set VITE_API_BASE as a GitHub Actions variable
#   pointing to your Vercel backend, e.g. https://backend-beta-gules-78.vercel.app/api
VITE_API_BASE=/api

# Local dev: backend proxy target (default localhost:3001)
# VITE_API_PROXY=http://localhost:3001
